# Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY=placeholder

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_SECRET_KEY=sk_test_placeholder

# Neon Postgres Database
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Supermemory
SUPERMEMORY_API_KEY=placeholder

# Vercel Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_PLACEHOLDER

# Auth Secrets for background workers
INTERNAL_CRON_SECRET=super_secret_string

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER
STRIPE_PRICE_PRO_INR=price_1_pro_inr_PLACEHOLDER
STRIPE_PRICE_TEAM_INR=price_1_team_inr_PLACEHOLDER
STRIPE_PRICE_PRO_USD=price_1_pro_usd_PLACEHOLDER
STRIPE_PRICE_TEAM_USD=price_1_team_usd_PLACEHOLDER

# Razorpay
RAZORPAY_KEY_ID=rzp_test_PLACEHOLDER
RAZORPAY_KEY_SECRET=rzp_secret_PLACEHOLDER
RAZORPAY_WEBHOOK_SECRET=rzp_wh_secret_PLACEHOLDER
RAZORPAY_PLAN_PRO_INR=plan_pro_inr_PLACEHOLDER
RAZORPAY_PLAN_TEAM_INR=plan_team_inr_PLACEHOLDER

# Feature flags
FEATURE_BILLING_ENABLED=true
FEATURE_ASYNC_INGESTION_ENABLED=true
FEATURE_PUBLIC_LANDING_ENABLED=true
